#!/bin/sh
set -e

# Replace libnss3's static Mozilla-bundle module (libnssckbi.so) with a symlink
# to p11-kit-trust.so, so NSS apps trust the system p11-kit store. The real
# module is preserved as libnssckbi.so.distrib.
#
# Re-asserted via a dpkg file trigger on the libnssckbi.so path: when libnss3 is
# upgraded it re-unpacks its own file over our symlink, and the trigger fires at
# the end of the transaction to restore the bridge (keeping .distrib in sync
# with libnss3's current module). HaLOS is arm64-only, so the path is fixed.

lib=/usr/lib/aarch64-linux-gnu/libnssckbi.so
trust=/usr/lib/aarch64-linux-gnu/pkcs11/p11-kit-trust.so

assert_bridge() {
    [ -e "$trust" ] || return 0
    if [ -L "$lib" ]; then
        [ "$(readlink "$lib")" = "$trust" ] || ln -sf "$trust" "$lib"
    elif [ -f "$lib" ]; then
        mv -f "$lib" "${lib}.distrib"
        ln -sf "$trust" "$lib"
    fi
}

case "$1" in
    configure|triggered)
        assert_bridge
        ;;
esac

#DEBHELPER#

exit 0
